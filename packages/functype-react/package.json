{
  "name": "functype-react",
  "version": "1.6.1",
  "description": "React bindings for functype — ADT-aware hooks and exhaustive pattern matching components",
  "keywords": [
    "functype",
    "react",
    "hooks",
    "pattern-matching",
    "adt",
    "option",
    "either",
    "task",
    "typescript",
    "functional"
  ],
  "author": "jordan.burke@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/jordanburke/functype/tree/main/packages/functype-react",
  "bugs": {
    "url": "https://github.com/jordanburke/functype/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanburke/functype",
    "directory": "packages/functype-react"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "eslint src --max-warnings 0",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate"
  },
  "peerDependencies": {
    "functype": ">=0.60.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "fast-check": "^4.8.0",
    "functype": "workspace:^",
    "jsdom": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./match": {
      "types": "./dist/match/index.d.ts",
      "import": "./dist/match/index.js",
      "default": "./dist/match/index.js"
    },
    "./async": {
      "types": "./dist/async/index.d.ts",
      "import": "./dist/async/index.js",
      "default": "./dist/async/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js",
      "default": "./dist/forms/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "prettier": "ts-builds/prettier",
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
