{
  "name": "functype-os",
  "version": "1.2.0",
  "description": "Functional OS utilities using functype data structures — env vars, path expansion, file ops, platform detection",
  "keywords": [
    "functype",
    "functional",
    "os",
    "env",
    "path",
    "platform",
    "typescript"
  ],
  "author": "jordan.burke@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/jordanburke/functype/tree/main/packages/functype-os",
  "bugs": {
    "url": "https://github.com/jordanburke/functype/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanburke/functype",
    "directory": "packages/functype-os"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate"
  },
  "peerDependencies": {
    "functype": ">=0.60.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "eslint-config-prettier": "^10.1.8",
    "functype": "workspace:^",
    "ts-builds": "^2.8.1",
    "tsdown": "^0.22.1",
    "vitest": "^4.1.8"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js",
      "default": "./dist/env/index.js"
    },
    "./path": {
      "types": "./dist/path/index.d.ts",
      "import": "./dist/path/index.js",
      "default": "./dist/path/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "import": "./dist/fs/index.js",
      "default": "./dist/fs/index.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js",
      "default": "./dist/platform/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "default": "./dist/errors/index.js"
    },
    "./process": {
      "types": "./dist/process/index.d.ts",
      "import": "./dist/process/index.js",
      "default": "./dist/process/index.js"
    }
  },
  "files": [
    "lib",
    "dist"
  ],
  "prettier": "ts-builds/prettier",
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
